GEMINI_API_KEY=your_gemini_api_key_here
# Get your free key at https://aistudio.google.com
# Leave blank to run in MOCK MODE (simulated AI responses)

# Anthropic Claude key (used by feasibility/report agents — optional, falls back to Gemini)
ANTHROPIC_API_KEY=

# Comma-separated frontend origins allowed by CORS, in addition to localhost ports.
# Any *.up.railway.app origin is already allowed by regex. Use "*" to allow all (disables credentials).
ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# $PORT is injected by Railway via the Procfile — no need to set locally.
