# Backend origin (no trailing /api). Leave unset in local dev — vite.config.js proxies /api to 127.0.0.1:8000.
# On Railway: set this to the public URL of the backend service.
VITE_BACKEND_URL=https://your-backend.up.railway.app

# Optional: URL of the standalone balloon-editor app. If unset, the "Open Editor" button is hidden.
VITE_BALLOON_EDITOR_URL=https://your-balloon-editor.up.railway.app
